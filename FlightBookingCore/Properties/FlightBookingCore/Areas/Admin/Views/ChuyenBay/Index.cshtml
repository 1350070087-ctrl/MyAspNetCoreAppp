@model IEnumerable<FlightBookingCore.Models.ChuyenBay> // Khai báo kiểu dữ liệu Model nhận được

@{
    ViewData["Title"] = "Quản lý Chuyến bay - Admin";
    Layout = "_LayoutAdmin"; // Giả định bạn đã tạo file Layout riêng cho Admin
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary"><i class="fas fa-plane"></i> Danh sách Chuyến bay</h2>
        <a asp-action="Create" class="btn btn-success btn-lg">
            <i class="fas fa-plus-circle"></i> Thêm chuyến bay mới
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null) // Hiển thị thông báo thành công (nếu có)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle">
                    <thead class="table-light text-uppercase text-muted">
                        <tr>
                            <th>Mã CB</th>
                            <th>Chặng bay</th>
                            <th>Ngày khởi hành</th>
                            <th>Giá vé</th>
                            <th>Số ghế trống</th>
                            <th class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var chuyenBay in Model) // Duyệt qua từng chuyến bay trong CSDL
                        {
                            <tr>
                                <td class="fw-bold text-primary">@chuyenBay.MaChuyenBay</td>
                                <td>
                                    <span class="fw-bold">@chuyenBay.DiemDi</span>
                                    <i class="fas fa-arrow-right text-muted mx-2"></i>
                                    <span class="fw-bold">@chuyenBay.DiemDen</span>
                                </td>
                                <td>
                                    <i class="fas fa-calendar-alt text-muted me-1"></i>
                                    @chuyenBay.NgayGioKhoiHanh.ToString("dd/MM/yyyy") <br>
                                    <i class="fas fa-clock text-muted me-1"></i>
                                    @chuyenBay.NgayGioKhoiHanh.ToString("HH:mm")
                                </td>
                                <td class="text-danger fw-bold">@chuyenBay.GiaVe.ToString("N0") VNĐ</td>
                                <td>
                                    @if (chuyenBay.SoGheTrong > 10)
                                    {
                                        <span class="badge bg-success">@chuyenBay.SoGheTrong</span>
                                    }
                                    else if (chuyenBay.SoGheTrong > 0)
                                    {
                                        <span class="badge bg-warning text-dark">Chỉ còn @chuyenBay.SoGheTrong</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Hết ghế</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="btn-group" role="group">
                                        <a asp-action="Edit" asp-route-id="@chuyenBay.MaChuyenBay" class="btn btn-outline-primary btn-sm" title="Chỉnh sửa">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@chuyenBay.MaChuyenBay" class="btn btn-outline-danger btn-sm" title="Xóa" onclick="return confirm('Bạn có chắc chắn muốn xóa chuyến bay này không?');">
                                            <i class="fas fa-trash-alt"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://kit.fontawesome.com/your-font-awesome-kit.js" crossorigin="anonymous"></script> 
}
