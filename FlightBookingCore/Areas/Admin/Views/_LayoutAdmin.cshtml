<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FlightBooking Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body>
    <div class="d-flex" id="wrapper">
        <div class="bg-light border-right" id="sidebar-wrapper">
            <div class="sidebar-heading text-center py-4 fs-4 fw-bold text-uppercase border-bottom">
                <i class="fas fa-plane-departure me-2"></i> Admin
            </div>
            <div class="list-group list-group-flush">
                <a asp-area="Admin" asp-controller="Home" asp-action="Index" class="list-group-item list-group-item-action bg-light">
                    <i class="fas fa-tachometer-alt me-2"></i> Dashboard
                </a>
                <a asp-area="Admin" asp-controller="ChuyenBay" asp-action="Index" class="list-group-item list-group-item-action bg-light">
                    <i class="fas fa-plane me-2"></i> Quản lý Chuyến bay
                </a>
                <a asp-area="Admin" asp-controller="SanBay" asp-action="Index" class="list-group-item list-group-item-action bg-light">
                    <i class="fas fa-map-marker-alt me-2"></i> Quản lý Sân bay
                </a>
                <a asp-area="Admin" asp-controller="DatVe" asp-action="Index" class="list-group-item list-group-item-action bg-light">
                    <i class="fas fa-ticket-alt me-2"></i> Quản lý Đơn đặt vé
                </a>
                <a asp-area="Admin" asp-controller="KhachHang" asp-action="Index" class="list-group-item list-group-item-action bg-light">
                    <i class="fas fa-users me-2"></i> Quản lý Khách hàng
                </a>
                <hr class="my-2">
                <a asp-area="" asp-controller="Home" asp-action="Index" class="list-group-item list-group-item-action bg-light text-danger">
                    <i class="fas fa-home me-2"></i> Quay lại trang chủ
                </a>
            </div>
        </div>
        <div id="page-content-wrapper">
            <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm">
                <div class="container-fluid">
                    <button class="btn btn-outline-primary" id="menu-toggle">
                        <i class="fas fa-bars"></i>
                    </button>
                    <div class="collapse navbar-collapse" id="navbarSupportedContent">
                        <ul class="navbar-collapse navbar-nav ms-auto mt-2 mt-lg-0">
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                    <i class="fas fa-user-circle me-1"></i> Admin User
                                </a>
                                <div class="dropdown-menu dropdown-menu-end" aria-labelledby="navbarDropdown">
                                    <a class="dropdown-item" href="#">Thông tin cá nhân</a>
                                    <div class="dropdown-divider"></div>
                                    <a class="dropdown-item" href="#">Đăng xuất</a>
                                </div>
                            </li>
                        </ul>
                    </div>
                </div>
            </nav>
            <div class="container-fluid p-4">
                @RenderBody() // Nơi nội dung cụ thể của từng trang sẽ được nhúng vào
            </div>
            </div>
        </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.min.js"></script>
    <script src="~/js/admin.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false) // Nơi nhúng các script cụ thể của từng trang

    <script>
        $("#menu-toggle").click(function(e) {
            e.preventDefault();
            $("#wrapper").toggleClass("toggled");
        });
    </script>
</body>
</html>
